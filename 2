def write_md(path, title, sections):
    lines = [f'# {title}', '']
    for heading, content in sections:
        lines += [f'## {heading}', '']
        if isinstance(content, str):
            lines += [content, '']
        else:
            for item in content:
                if isinstance(item, tuple):
                    lines += [f'### {item[0]}', '', item[1], '']
                else:
                    lines += [item, '']
    path.write_text('\n'.join(lines).strip()+'\n', encoding='utf-8')

